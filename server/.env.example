# ========================================
# Environment
# ========================================
NODE_ENV=development # Sử dụng "production" khi deploy thực tế

# ========================================
# Cấu hình Database MySQL
# ========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=thue_tro

# ========================================
# Cấu hình Server
# ========================================
PORT=8000
CLIENT_URL=http://localhost:5173 # URL của Frontend để cấu hình CORS

# ========================================
# Cấu hình Bảo mật (BẮT BUỘC ĐỔI TRÊN PRODUCTION)
# ========================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ========================================
# Geocoding API (Tùy chọn - Premium Feature)
# ========================================
# Google Maps Geocoding API (Độ chính xác cao cho địa chỉ Việt Nam)
# Hướng dẫn setup: https://console.cloud.google.com/google/maps-apis/credentials
# Nếu không có API key -> Hệ thống tự động dùng Nominatim (OpenStreetMap - Free)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ========================================
# AI Services & External APIs
# ========================================
# GROQ_API_KEY=your_groq_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here